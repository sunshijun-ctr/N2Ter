# Copy to `.env` (next to docker-compose.yml); Docker Compose reads it for the
# ${VAR} substitutions in docker-compose.yml. Leave LLM_API_KEY empty to run the
# stack in deterministic fallback mode (no external AI calls).

# ----- LLM (OpenAI-compatible Chat Completions) -----
# LLM_PROVIDER picks a preset (openai | deepseek) that fills the base URL and a
# default model, so for those you only need to set the API key. LLM_BASE_URL /
# LLM_MODEL override the preset and let you point at any OpenAI-compatible API.
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- DeepSeek example (https://platform.deepseek.com) ---
# Uncomment these two lines to use DeepSeek for the LLM.
# Models: deepseek-chat (V3) or deepseek-reasoner (R1).
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-your-deepseek-key

# ----- Embedding (independent of the LLM: own endpoint + key, no inheritance) -----
# Leave these blank to run vectorisation in offline pseudo-vector mode. Point
# them at any OpenAI-compatible /embeddings endpoint (e.g. OpenAI, or a BGE-M3
# server) to enable real semantic retrieval — regardless of which LLM you use.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3

# ----- Rerank (BGE-reranker style endpoint; blank = passthrough) -----
# Independent of the LLM and embedding configs. RERANK_MODEL is sent in the
# request body, so set it to whatever your rerank endpoint expects.
RERANK_URL=
RERANK_API_KEY=
RERANK_MODEL=bge-reranker-v2-m3

# ----- Async task dispatch (a worker is part of the stack, so default on) -----
ASYNC_TASKS_ENABLED=true

# Chapters processed concurrently during LLM preprocessing. Raise if your
# provider quota (RPM/TPM) allows; lower if you hit rate limits.
PREPROCESS_CONCURRENCY=5

# Conversation agent (ReAct) loop: max tool-calling rounds before a forced
# answer, and per-tool call cap (chapter_search is exempt / unlimited).
AGENT_MAX_ITERS=2
AGENT_TOOL_CALL_LIMIT=3

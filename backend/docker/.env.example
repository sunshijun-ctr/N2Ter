# Copy to `.env` (next to docker-compose.yml); Docker Compose reads it for the
# ${VAR} substitutions in docker-compose.yml. Leave LLM_API_KEY empty to run the
# stack in deterministic fallback mode (no external AI calls).

# ----- LLM (OpenAI-compatible Chat Completions) -----
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ----- Embedding (defaults to the LLM credentials when blank) -----
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3

# ----- Rerank (BGE-reranker style endpoint; blank = passthrough) -----
RERANK_URL=
RERANK_API_KEY=

# ----- Async task dispatch (a worker is part of the stack, so default on) -----
ASYNC_TASKS_ENABLED=true
